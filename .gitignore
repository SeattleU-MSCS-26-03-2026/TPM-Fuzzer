# Disallow everything
*

# Allow only
!.dockerignore
!.github/
!.github/**/*
!.gitignore
!Dockerfile*
!README.md
!docker-compose.yml
!fuzzer/
!fuzzer/.clang-format
!fuzzer/CMakeLists.txt
!fuzzer/Dockerfile
!fuzzer/include/
!fuzzer/include/**/*
!fuzzer/scripts/
!fuzzer/scripts/**/*
!fuzzer/src
!fuzzer/src/**/*
!fuzzer/vendor
!fuzzer/vendor/**/*
!scripts/
!scripts/**/*
!seeds/
!seeds/**/*

# Allow new test runner directory
!test_runner/
!test_runner/**/*

