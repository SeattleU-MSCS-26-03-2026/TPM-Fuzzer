# Disallow everything
*

# Allow only
!.dockerignore
!.github/
!.github/**/*
!.gitignore
!Dockerfile*
!README.md
!docker-compose.yml
!fuzzer/
!fuzzer/.clang-format
!fuzzer/CMakeLists.txt
!fuzzer/Dockerfile
!fuzzer/include/
!fuzzer/include/**/*
!fuzzer/scripts/
!fuzzer/scripts/**/*
!fuzzer/src
!fuzzer/src/**/*
!fuzzer/tests
!fuzzer/tests/**/*
!fuzzer/vendor
!fuzzer/vendor/**/*
!patches/
!patches/**/*
!scripts/
!scripts/**/*
!seeds/
!seeds/**/*
!coverage-history/
!coverage-history/**/*

# Always disallow
__pycache__/
